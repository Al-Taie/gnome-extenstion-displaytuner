<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.displaytuner" path="/org/gnome/shell/extensions/displaytuner/">
    
    <key name="profiles" type="s">
      <default>'{}'</default>
      <summary>JSON Dictionary of Monitor Profiles</summary>
    </key>

    <key name="target-connector" type="s">
      <default>'primary'</default>
      <summary>Currently selected connector in settings</summary>
    </key>

    <key name="global-enable" type="b">
      <default>true</default>
      <summary>Enable or disable all padding</summary>
    </key>

    <key name="shortcut-dim-up" type="as">
      <default>['&lt;Shift&gt;XF86MonBrightnessUp']</default>
      <summary>Shortcut to increase software brightness (default: Shift+BrightnessUp)</summary>
    </key>
    
    <key name="shortcut-dim-down" type="as">
      <default>['&lt;Shift&gt;XF86MonBrightnessDown']</default>
      <summary>Shortcut to decrease software brightness (default: BrightnessDown)</summary>
    </key>

  </schema>
</schemalist>